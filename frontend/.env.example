# =============================================================================
# RegulaForge - Frontend Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Base URL for the backend API
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Application name (displayed in the browser tab and UI)
VITE_APP_NAME=RegulaForge

# Sentry DSN for frontend error tracking (optional, leave blank to disable)
# VITE_SENTRY_DSN=
