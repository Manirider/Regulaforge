# =============================================================================
# RegulaForge - Production Environment Variables (example)
# Copy to .env and fill in your values
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
REGULAFORGE_ENVIRONMENT=production
REGULAFORGE_API_HOST=0.0.0.0
REGULAFORGE_API_PORT=8000
REGULAFORGE_API_WORKERS=4
REGULAFORGE_API_PREFIX=/api/v1
REGULAFORGE_DOCS_ENABLED=false

# ─── Database ────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
REGULAFORGE_DB_URL=postgresql+asyncpg://regulaforge:${DB_PASSWORD}@db:5432/regulaforge
REGULAFORGE_DB_POOL_SIZE=20
REGULAFORGE_DB_MAX_OVERFLOW=10
REGULAFORGE_DB_MIGRATE_ON_STARTUP=true

# ─── Cache (Redis) ──────────────────────────────────────────────────────────
REGULAFORGE_CACHE_URL=redis://:${REDIS_PASSWORD}@cache:6379/0
REGULAFORGE_CACHE_DEFAULT_TTL=300
REGULAFORGE_CACHE_MAX_CONNECTIONS=50

# ─── Message Broker (RabbitMQ) ──────────────────────────────────────────────
REGULAFORGE_BROKER_URL=amqp://guest:${RABBITMQ_DEFAULT_PASS}@broker:5672/
REGULAFORGE_BROKER_MAX_RETRIES=3
REGULAFORGE_BROKER_PREFETCH_COUNT=10

# ─── Security ────────────────────────────────────────────────────────────────
REGULAFORGE_SECRET_KEY=${SECRET_KEY}
REGULAFORGE_JWT_ALGORITHM=HS256
REGULAFORGE_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
REGULAFORGE_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REGULAFORGE_CORS_ORIGINS=https://app.regulaforge.example.com,https://admin.regulaforge.example.com
REGULAFORGE_RATE_LIMIT_ENABLED=true
REGULAFORGE_RATE_LIMIT_REQUESTS=100
REGULAFORGE_RATE_LIMIT_WINDOW_SECONDS=60

# ─── AI / LLM ────────────────────────────────────────────────────────────────
REGULAFORGE_LLM_PROVIDER=openai
REGULAFORGE_LLM_MODEL=gpt-4-turbo
REGULAFORGE_LLM_TEMPERATURE=0.1
REGULAFORGE_LLM_API_KEY=${LLM_API_KEY}
REGULAFORGE_EMBEDDING_MODEL=text-embedding-3-small
REGULAFORGE_CONFIDENCE_THRESHOLD=0.85

# ─── Monitoring ──────────────────────────────────────────────────────────────
REGULAFORGE_PROMETHEUS_ENABLED=true
REGULAFORGE_OPENTELEMETRY_ENABLED=true
REGULAFORGE_OTLP_ENDPOINT=http://otel-collector:4318
REGULAFORGE_SENTRY_ENABLED=true
REGULAFORGE_SENTRY_DSN=${SENTRY_DSN}
REGULAFORGE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Storage ─────────────────────────────────────────────────────────────────
REGULAFORGE_UPLOAD_DIR=/data/regulaforge/uploads
REGULAFORGE_MODEL_DIR=/data/regulaforge/models
REGULAFORGE_MAX_UPLOAD_SIZE_MB=50

# ─── Neo4j (Knowledge Graph) ───────────────────────────────────────────────
REGULAFORGE_NEO4J_URI=bolt://neo4j:7687
REGULAFORGE_NEO4J_USER=neo4j
REGULAFORGE_NEO4J_PASSWORD=${NEO4J_PASSWORD}

# ─── Docker Compose Specific ────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=regulaforge
