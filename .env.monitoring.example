# =============================================================================
# RegulaForge - Monitoring Stack Environment Variables
# Copy to .env.monitoring and fill in your values
# =============================================================================

# ─── Grafana ─────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD}
GF_SECURITY_SECRET_KEY=${SECRET_KEY}
GF_METRICS_USER=metrics
GF_METRICS_PASSWORD=${PROMETHEUS_PASSWORD}

# ─── Prometheus ──────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ─── Alertmanager ────────────────────────────────────────────────────────────
# (empty config for now; configure Slack/PagerDuty/OpsGenie as needed)

# ─── Loki ────────────────────────────────────────────────────────────────────
# (no additional env vars needed for basic config)

# ─── PostgreSQL Exporter ────────────────────────────────────────────────────
DATA_SOURCE_NAME=postgresql://regulaforge:${DB_PASSWORD}@db:5432/regulaforge?sslmode=disable
