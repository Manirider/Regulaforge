{
  "__inputs": [],
  "__requires": [],
  "title": "RegulaForge - SLO Dashboard",
  "uid": "regulaforge-slos",
  "tags": ["regulaforge", "slo", "production"],
  "timezone": "browser",
  "editable": false,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "text": "Breached" },
                "1": { "color": "green", "text": "Compliant" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.x",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg_over_time(up{job=\"regulaforge-api\"}[30d])",
          "legendFormat": "Uptime SLO",
          "refId": "A"
        }
      ],
      "title": "Uptime SLO (99.9% - 30d rolling)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "text": "Breached" },
                "1": { "color": "green", "text": "Compliant" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.x",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, avg(rate(regulaforge_http_request_duration_seconds_bucket{job=\"regulaforge-api\"}[5m]))) by (le) < 0.5",
          "legendFormat": "Latency SLO",
          "refId": "A"
        }
      ],
      "title": "Latency SLO (p95 < 500ms - 5m window)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "text": "Breached" },
                "1": { "color": "green", "text": "Compliant" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.x",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(regulaforge_http_requests_total{job=\"regulaforge-api\", status_code=~\"5..\"}[5m])) / sum(rate(regulaforge_http_requests_total{job=\"regulaforge-api\"}[5m])) < 0.001",
          "legendFormat": "Error Rate SLO",
          "refId": "A"
        }
      ],
      "title": "Error Rate SLO (< 0.1% - 5m window)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 3 },
      "id": 4,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg_over_time(up{job=\"regulaforge-api\"}[30d]) * 100",
          "legendFormat": "Uptime %",
          "refId": "A"
        }
      ],
      "title": "Uptime (30d rolling avg)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 3 },
      "id": 5,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, avg(rate(regulaforge_http_request_duration_seconds_bucket{job=\"regulaforge-api\"}[5m])) by (le))",
          "legendFormat": "p95 latency",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "0.5",
          "legendFormat": "SLO target (500ms)",
          "refId": "B"
        }
      ],
      "title": "API Latency (p95) vs SLO Target",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 3 },
      "id": 6,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(regulaforge_http_requests_total{job=\"regulaforge-api\", status_code=~\"5..\"}[5m])) / sum(rate(regulaforge_http_requests_total{job=\"regulaforge-api\"}[5m])) * 100",
          "legendFormat": "Error rate %",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "0.1",
          "legendFormat": "SLO target (0.1%)",
          "refId": "B"
        }
      ],
      "title": "Error Rate vs SLO Target",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 7,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - avg_over_time(up{job=\"regulaforge-api\"}[30d])) * 100 * 43800",
          "legendFormat": "Uptime error budget (minutes)",
          "refId": "A"
        }
      ],
      "title": "Error Budget Remaining (30d) - Uptime 99.9%",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "id": 8,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(regulaforge_http_requests_total{job=\"regulaforge-api\"}[5m])) * 0.001 * 86400",
          "legendFormat": "Daily error budget (requests)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(regulaforge_http_requests_total{job=\"regulaforge-api\", status_code=~\"5..\"}[5m])) * 86400",
          "legendFormat": "Actual daily errors",
          "refId": "B"
        }
      ],
      "title": "Error Rate Budget Burn (daily projection)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "id": 9,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg_over_time(up{job=\"regulaforge-api\"}[30d]) * 100",
          "legendFormat": "Uptime",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "99.9",
          "legendFormat": "SLO 99.9%",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "99.95",
          "legendFormat": "SLO 99.95%",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "99.99",
          "legendFormat": "SLO 99.99%",
          "refId": "D"
        }
      ],
      "title": "SLO Burn Rate - Multi-Tier Uptime Comparison",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 10,
      "options": {
        "dedupStrategy": "exact",
        "enableLogDetails": true,
        "prettifyLogJson": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{job=\"regulaforge-api\"} |= \"SLO\" | logfmt",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "SLO Events",
      "type": "logs"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 11,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (severity) (rate(regulaforge_ai_hallucination_rate[5m]))",
          "legendFormat": "Hallucination rate - {{ severity }}",
          "refId": "A"
        }
      ],
      "title": "AI Hallucination Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["regulaforge"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"] },
  "timezone": "browser",
  "version": 1
}
