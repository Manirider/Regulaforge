* text=auto eol=lf

# Python
*.py diff=python

# TypeScript
*.ts diff=typescript
*.tsx diff=typescript

# JavaScript
*.js diff=javascript
*.jsx diff=javascript

# Generated / vendored files
*.min.js linguist-generated=true
*.min.css linguist-generated=true
dist/** linguist-generated=true
*.pyc linguist-generated=true
*.pb.go linguist-generated=true
node_modules/** linguist-generated=true
.mypy_cache/** linguist-generated=true
.pytest_cache/** linguist-generated=true
.ruff_cache/** linguist-generated=true
__pycache__/** linguist-generated=true

# Lockfiles are vendored
poetry.lock linguist-generated=true
package-lock.json linguist-generated=true
Cargo.lock linguist-generated=true

# Binary files
*.pyc binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary
*.pdf binary
*.zip binary
*.tar.gz binary
