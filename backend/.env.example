# =============================================================================
# RegulaForge - Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ─── Application ─────────────────────────────────────────────────────────

# Environment: development, testing, production
REGULAFORGE_ENVIRONMENT=development

# Debug mode (enables detailed error pages, auto-reload)
REGULAFORGE_DEBUG=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
REGULAFORGE_LOG_LEVEL=DEBUG

# Output logs as JSON (recommended for production)
# REGULAFORGE_LOG_JSON=false

# API binding host and port
REGULAFORGE_API_HOST=0.0.0.0
REGULAFORGE_API_PORT=8000

# ─── Database ────────────────────────────────────────────────────────────

# PostgreSQL connection string (async with asyncpg driver)
REGULAFORGE_DB_URL=postgresql+asyncpg://regulaforge:regulaforge@localhost:5432/regulaforge

# Connection pool size
# REGULAFORGE_DB_POOL_SIZE=20

# Echo all SQL queries (development only)
# REGULAFORGE_DB_ECHO=false

# ─── Cache (Redis) ─────────────────────────────────────────────────────

REGULAFORGE_CACHE_URL=redis://localhost:6379/0

# Default TTL for cache entries in seconds
# REGULAFORGE_CACHE_DEFAULT_TTL=300

# ─── Message Broker (RabbitMQ) ──────────────────────────────────────────

REGULAFORGE_BROKER_URL=amqp://guest:guest@localhost:5672/

# ─── Security ────────────────────────────────────────────────────────────

# Secret key for JWT signing (generate with: openssl rand -hex 32)
REGULAFORGE_SECURITY_SECRET_KEY=your-super-secret-key-at-least-32-chars-long

# JWT signing algorithm
# REGULAFORGE_SECURITY_ALGORITHM=HS256

# Access token expiration in minutes
# REGULAFORGE_SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Comma-separated list of allowed CORS origins
REGULAFORGE_SECURITY_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Comma-separated list of allowed hosts (for Host header validation)
# REGULAFORGE_ALLOWED_HOSTS=localhost,regulaforge.io

# ─── AI / LLM ────────────────────────────────────────────────────────────

# LLM provider: openai, anthropic, azure, ollama, etc.
# REGULAFORGE_AI_LLM_PROVIDER=openai

# Model identifier
# REGULAFORGE_AI_LLM_MODEL=gpt-4-turbo

# Sampling temperature (0.0 - 1.0)
# REGULAFORGE_AI_LLM_TEMPERATURE=0.1

# API key for the LLM provider
# REGULAFORGE_AI_LLM_API_KEY=sk-your-openai-api-key

# Embedding model
# REGULAFORGE_AI_EMBEDDING_MODEL=text-embedding-3-large

# Confidence threshold for AI suggestions (0.0 - 1.0)
# REGULAFORGE_AI_CONFIDENCE_THRESHOLD=0.85

# ─── Monitoring ──────────────────────────────────────────────────────────

# Enable Prometheus metrics endpoint
# REGULAFORGE_MONITORING_ENABLE_PROMETHEUS=true

# Sentry DSN for error tracking (leave blank to disable)
# REGULAFORGE_MONITORING_SENTRY_DSN=

# OpenTelemetry collector endpoint
# REGULAFORGE_MONITORING_OTLP_ENDPOINT=

# ─── MLflow ──────────────────────────────────────────────────────────────

# MLflow Tracking URI
# REGULAFORGE_MLFLOW_TRACKING_URI=http://localhost:5000

# ─── Storage ─────────────────────────────────────────────────────────────

# Data and upload directories
# REGULAFORGE_DATA_DIR=/data/regulaforge
# REGULAFORGE_UPLOAD_DIR=/data/regulaforge/uploads
